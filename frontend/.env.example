# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Where the n8n webhooks live. On Vercel this can be a relative /api/*
# path proxied server-side (see app/api/*/route.ts). On the Capacitor
# native build there is no server to proxy through, so it must point
# directly at your deployed API base (Vercel URL or n8n host).
NEXT_PUBLIC_API_BASE_URL=your-public-api-base-url 

# Server-side only — never exposed to the client bundle. Used by the
# Next.js API routes to authenticate with n8n webhooks.
AIRINTEL_SHARED_SECRET=your-airintel-shared-secret

N8N_HOST=your-n8n-host

# OneSignal (client-safe app id; REST key stays server-side / in n8n only)
NEXT_PUBLIC_ONESIGNAL_APP_ID=your-onesignal-app-id
NEXT_PUBLIC_ONESIGNAL_SAFARI_WEB_ID=your-onesignal-safari-web-id
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME =your-telegram-bot-username

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY = your-google-maps-api-key

GEMINI_API_KEY = your-gemini-api-key
